<Content type="html"><![CDATA[


<!DOCTYPE html>
<html lang="en-us">
<head>
<meta charset="utf-8"/>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/kelsimsk/99bu@main/style.css"/>
<style>
    canvas:focus { outline: none; }
    html, body {
        padding: 0; margin: 0; overflow: hidden;
        -webkit-touch-callout: none; -webkit-user-select: none;
        -khtml-user-select: none; -moz-user-select: none;
        -ms-user-select: none; user-select: none;
        -webkit-tap-highlight-color: rgba(0,0,0,0);
        height: 100%;
    }
</style>
</head>
<body class="dark">

<div id="unity-container" class="unity-desktop">
    <canvas id="unity-canvas" tabindex="-1"></canvas>
</div>

<div id="loading-cover" style="display:none;">
    <div id="unity-loading-bar">
        <div id="unity-logo"><img src="https://cdn.jsdelivr.net/gh/kelsimsk/99bu@main/Images/logo.png"/></div>
        <div id="unity-progress-bar-empty" style="display:none;">
            <div id="unity-progress-bar-full"></div>
        </div>
        <div class="spinner"></div>
    </div>
</div>

<script>
/* ============================================================
   navigator.language OVERRIDE
   Framework'deki _GeneralLanguage_js ve _GeneralEnvirData_js
   navigator.language'ı direkt okur → 'en' olarak sabitle
   ============================================================ */
const _origNavLang = Object.getOwnPropertyDescriptor(navigator, 'language');
Object.defineProperty(navigator, 'language',    { get: () => 'en', configurable: true });
Object.defineProperty(navigator, 'userLanguage',{ get: () => 'en', configurable: true });
/* languages dizisi de override */
try {
    Object.defineProperty(navigator, 'languages', { get: () => ['en', 'en-US'], configurable: true });
} catch(e) {}

/* ============================================================
   PART CONFIG
   ============================================================ */
const BUILD_URL  = "https://cdn.jsdelivr.net/gh/kelsimsk/99bu@2dc5020/Build";
const DATA_PARTS = 4;
const WASM_PARTS = 11;

/* ============================================================
   GLOBALS — Unity framework'ün beklediği değişkenler
   ============================================================ */
const NO_DATA = 'no data';

var initYSDK  = true;
var initGame  = false;
var ysdk = {
    environment: { i18n: { lang: 'en', tld: 'com' }, app: { id: '0' }, browser: { lang: 'en' }, payload: '' },
    deviceInfo:  { type: 'desktop', isMobile: ()=>false, isDesktop: ()=>true, isTablet: ()=>false, isTV: ()=>false },
    screen:      { fullscreen: { status: 'off', request: ()=>{}, exit: ()=>{} } },
    adv:         { showFullscreenAdv: ()=>{}, showRewardedVideo: ()=>{}, showBannerAdv: ()=>Promise.resolve({stickyAdvIsShowing:false}), hideBannerAdv: ()=>Promise.resolve(), getBannerAdvStatus: ()=>Promise.resolve({stickyAdvIsShowing:false}) },
    auth:        { openAuthDialog: ()=>Promise.resolve() },
    feedback:    { canReview: ()=>Promise.resolve({value:false, reason:'YSDK_DISABLED'}), requestReview: ()=>Promise.resolve({feedbackSent:false}) },
    shortcut:    { canShowPrompt: ()=>Promise.resolve({canShow:false}), showPrompt: ()=>Promise.resolve({outcome:'rejected'}) },
    features:    { LoadingAPI: null, GameplayAPI: { start: ()=>{}, stop: ()=>{} }, GamesAPI: { getAllGames: ()=>Promise.reject() } },
    getLeaderboards: ()=>Promise.resolve({ setLeaderboardScore:()=>{}, getLeaderboardDescription:()=>Promise.resolve({default:false,description:{invert_sort_order:false,score_format:{options:{decimal_offset:0}},type:'numeric'}}), getLeaderboardEntries:()=>Promise.resolve({entries:[]}) }),
    getPlayer:   ()=>Promise.resolve({ getMode:()=>'lite', getName:()=>'', getUniqueID:()=>'stub-id', getPhoto:()=>'', getPayingStatus:()=>'unknown', getData:()=>Promise.resolve({}), setData:()=>Promise.resolve(), getStats:()=>Promise.resolve({}), setStats:()=>Promise.resolve(), incrementStats:()=>Promise.resolve() }),
    getPayments: ()=>Promise.reject(new Error('payments not available')),
    getFlags:    ()=>Promise.resolve({}),
    serverTime:  ()=>Date.now(),
    clipboard:   { writeText: ()=>Promise.resolve() },
    dispatchEvent: ()=>{},
    onEvent: ()=>{},
    EVENTS: { EXIT: 'EXIT', HISTORY_BACK: 'HISTORY_BACK' },
};
var player    = null;
var payments  = null;
var leaderboards     = null;
var cloudSaves       = NO_DATA;
var paymentsData     = NO_DATA;
var playerData       = NO_DATA;
var environmentData  = NO_DATA;
var reviewData       = 'false';
var statsSaves       = NO_DATA;
var allGamesData     = NO_DATA;
var gameLabelData    = 'false';
var flasgsData       = NO_DATA;
var nowFullAdOpen    = false;

let ygGameInstance = null;

function LogStyledMessage(msg, style) {
    console.log('%c' + msg, style || 'color:#FFDF73;background:#454545');
}

/* ============================================================
   YG2Instance — Unity'ye mesaj gönderir
   ============================================================ */
function YG2Instance(method, arg) {
    if (!ygGameInstance) return;
    try {
        if (arg !== undefined) ygGameInstance.SendMessage('YG2Instance', method, arg);
        else                   ygGameInstance.SendMessage('YG2Instance', method);
    } catch(e) {}
}

/* ============================================================
   YSDK STUB FONKSİYONLARI — hepsi boş / olumlu döner
   ============================================================ */
function FocusGame() { window.focus(); canvas && canvas.focus(); }

function InitGame() {
    initGame = true;
    setTimeout(function () {
        if (nowFullAdOpen === true) YG2Instance('OpenInterAdv');
    }, 100);
}

/* Cloud */
function SaveCloud()   {}
function LoadCloud()   { YG2Instance('SetLoadSaves', NO_DATA); return Promise.resolve(NO_DATA); }

/* Ads */
function StickyAdActivity() {}
function RewardedAdvShow(id) {
    YG2Instance('OpenRewardedAdv');
    YG2Instance('RewardAdv', id);
    YG2Instance('CloseRewardedAdv');
}
function InterAdvShow() {
    nowFullAdOpen = true;
    setTimeout(() => {
        nowFullAdOpen = false;
        YG2Instance('CloseInterAdv', 'true');
        FocusGame();
    }, 50);
}

/* Payments */
function BuyPayments(id)    { YG2Instance('OnPurchaseFailed', id); }
function ConsumePurchase()  {}
function ConsumePurchases() {}
function InitPayments()     { YG2Instance('PaymentsEntries', NO_DATA); return Promise.resolve(NO_DATA); }

/* Auth */
function OpenAuthDialog()   {}
function InitPlayer() {
    const j = JSON.stringify({ playerAuth:'rejected', playerName:'unauthorized', playerId:'unauthorized', playerPhoto:'null', payingStatus:'unknown' });
    YG2Instance('SetAuth', j);
    return Promise.resolve(j);
}
function NotAuthorized() {
    return JSON.stringify({ playerAuth:'rejected', playerName:'unauthorized', playerId:'unauthorized', playerPhoto:'null', payingStatus:'unknown' });
}

/* Leaderboard */
function SetLeaderboard()  {}
function GetLeaderboard(nameLB) {
    YG2Instance('LeaderboardEntries', JSON.stringify({
        entries:'no data', ranks:[], photos:[], names:[], scores:[], uniqueIDs:[], extraDataArray:[]
    }));
}
function InitLeaderboards() { return Promise.resolve(null); }
function EntriesLB()        { return {}; }

/* Review */
function InitReview()    { YG2Instance('ReviewSent', 'false'); return Promise.resolve('false'); }
function Review()        { YG2Instance('ReviewSent', 'false'); FocusGame(); }

/* Stats */
function SetState()      {}
function GetStats()      { YG2Instance('ReceiveStats', NO_DATA); return Promise.resolve(NO_DATA); }
function SetAllStats()   {}

/* Games / URL */
function GetAllGames()   { return Promise.resolve(NO_DATA); }

/* Game Label (shortcut) */
function InitGameLabel()        { return Promise.resolve('false'); }
function GameLabelShowDialog()  { YG2Instance('OnGameLabelFail'); FocusGame(); }

/* Flags */
function GetFlags()      { return Promise.resolve(NO_DATA); }

/* Environment */
function RequestingEnvironmentData() {
    const j = JSON.stringify({
        language:'en', domain:'com', deviceType:'desktop',
        isMobile:false, isDesktop:true, isTablet:false, isTV:false,
        appID:'0', browserLang:'en', payload:'', platform:'', browser:'Other'
    });
    YG2Instance('SetEnvirData', j);
    return Promise.resolve(j);
}

/* TV */
function TVInit() {}

/* ============================================================
   PART LOADER — parçaları indir, birleştir, Blob URL üret
   ============================================================ */
const loadingCover   = document.querySelector("#loading-cover");
const progressBarEmpty = document.querySelector("#unity-progress-bar-empty");
const progressBarFull  = document.querySelector("#unity-progress-bar-full");
const spinner          = document.querySelector('.spinner');

loadingCover.style.display = "";

function setProgress(pct) {
    if (spinner)        spinner.style.display        = "none";
    if (progressBarEmpty) progressBarEmpty.style.display = "";
    if (progressBarFull)  progressBarFull.style.width   = pct + "%";
}

async function fetchParts(filename, count, startPct, endPct) {
    const step   = (endPct - startPct) / count;
    const chunks = [];
    for (let i = 0; i < count; i++) {
        const resp = await fetch(`${BUILD_URL}/${filename}.part${i}`);
        if (!resp.ok) throw new Error(`HTTP ${resp.status} → ${BUILD_URL}/${filename}.part${i}`);
        chunks.push(new Uint8Array(await resp.arrayBuffer()));
        setProgress(Math.round(startPct + step * (i + 1)));
    }
    const total  = chunks.reduce((s, c) => s + c.length, 0);
    const merged = new Uint8Array(total);
    let offset = 0;
    for (const c of chunks) { merged.set(c, offset); offset += c.length; }
    return URL.createObjectURL(new Blob([merged]));
}

/* ============================================================
   MAIN — parçaları yükle, Unity'yi başlat, SDK mesajlarını gönder
   ============================================================ */
(async () => {
    try {
        setProgress(2);

        const [dataUrl, wasmUrl] = await Promise.all([
            fetchParts("Build.data.br",  DATA_PARTS, 2,  40),
            fetchParts("Build.wasm.br",  WASM_PARTS, 40, 88),
        ]);

        setProgress(92);

        const canvas = document.querySelector("#unity-canvas");
        if (/iPhone|iPad|iPod|Android/i.test(navigator.userAgent)) {
            document.querySelector("#unity-container").className = "unity-mobile";
        }

        const loaderScript  = document.createElement("script");
        loaderScript.src    = BUILD_URL + "/Build.loaders.js";
        loaderScript.onload = () => {
            createUnityInstance(canvas, {
                dataUrl:             dataUrl,
                frameworkUrl:        BUILD_URL + "/Build.framework.js",
                codeUrl:             wasmUrl,
                streamingAssetsUrl:  "StreamingAssets",
                companyName:         "",
                productName:         "!",
                productVersion:      "0.5",
            }, (p) => {
                setProgress(Math.round(88 + p * 10));
            }).then((inst) => {
                ygGameInstance = inst;
                loadingCover.style.display = "none";

                /* SDK hazır sinyalleri */
                setTimeout(() => {
                    YG2Instance('InitSDKComplete');
                }, 300);
                setTimeout(() => {
                    YG2Instance('SetEnvirData',    JSON.stringify({ language:'en', domain:'com', deviceType:'desktop', isMobile:false, isDesktop:true, isTablet:false, isTV:false, appID:'0', browserLang:'en', payload:'', platform:'', browser:'Other' }));
                    YG2Instance('SetAuth',         NotAuthorized());
                    YG2Instance('SetLoadSaves',    NO_DATA);
                    YG2Instance('ReceiveStats',    NO_DATA);
                    YG2Instance('PaymentsEntries', NO_DATA);
                    YG2Instance('CloseInterAdv',   'false');
                }, 600);

                canvas.focus();
            }).catch(e => {
                console.error(e);
                if (progressBarFull) progressBarFull.parentElement.textContent = "Hata: " + e;
            });
        };
        document.body.appendChild(loaderScript);

    } catch (err) {
        console.error("Yükleme hatası:", err);
        if (progressBarFull) progressBarFull.parentElement.textContent = "Yükleme hatası: " + err.message;
    }
})();

/* Context menu kapat */
document.addEventListener('contextmenu', e => e.preventDefault());
document.addEventListener('visibilitychange', function () {
    if (initGame) {
        YG2Instance('SetFocusWindowGame', document.hidden ? 'false' : 'true');
    }
});
window.addEventListener('pointerdown', FocusGame);
window.addEventListener('touchstart',  FocusGame);

/* Pointer lock fix */
const _oPRL = Element.prototype.requestPointerLock;
Element.prototype.requestPointerLock = async function(...args) {
    try { (args[0] ||= {}).unadjustedMovement = true; await _oPRL.apply(this, args); } catch(e) {}
};
</script>

</body>
</html>

